<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".BattleActivity">

    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="60dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btn_attack"
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:text="기본 공격" />

        <Button
            android:id="@+id/btn_skill"
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="스킬" />

    </LinearLayout>

    <!-- 내 캐릭터 -->

    <!-- 내 캐릭터 이미지 (좌측 하단) -->
    <ImageView
        android:id="@+id/iv_my_character"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginStart="50dp"
        android:layout_marginBottom="224dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:srcCompat="@tools:sample/avatars" />

    <!-- 내 닉네임: 이미지 아래 중앙 정렬 -->
    <TextView
        android:id="@+id/tv_my_nickname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="내 이름"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/iv_my_character"
        app:layout_constraintStart_toStartOf="@id/iv_my_character"
        app:layout_constraintEnd_toEndOf="@id/iv_my_character" />

    <!-- 내 캐릭터 이름: 이미지와 같은 수직 중심에 위치, 능력치 위 -->
    <TextView
        android:id="@+id/tv_my_character_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="내 캐릭터"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginEnd="65dp"
        app:layout_constraintBottom_toTopOf="@id/tv_my_attack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_my_character"
        android:textAlignment="viewEnd" />

    <!-- 공격력: 캐릭터 이름 바로 아래 세로 정렬 -->
    <TextView
        android:id="@+id/tv_my_attack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="65dp"
        android:text="Attack"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tv_my_character_name"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_my_hp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="65dp"
        android:text="HP"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tv_my_attack"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_my_dirt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="65dp"
        android:text="Dirt"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tv_my_hp"
        app:layout_constraintBottom_toBottomOf="@id/iv_my_character"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- 상대 캐릭터 -->

    <!-- 상대 캐릭터 이미지 (우측 상단) -->
    <ImageView
        android:id="@+id/iv_opponent_character"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="120dp"
        android:layout_marginEnd="50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@tools:sample/avatars" />

    <!-- 상대 닉네임: 이미지 바로 위 중앙 정렬 -->
    <TextView
        android:id="@+id/tv_opponent_nickname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        android:text="상대 이름"
        android:textAlignment="center"
        app:layout_constraintBottom_toTopOf="@id/iv_opponent_character"
        app:layout_constraintStart_toStartOf="@id/iv_opponent_character"
        app:layout_constraintEnd_toEndOf="@id/iv_opponent_character" />

    <!-- 상대 캐릭터 이름: 이미지와 같은 수직 중앙에 위치, 능력치 위 -->
    <TextView
        android:id="@+id/tv_opponent_character_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="상대 캐릭터"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginStart="65dp"
        app:layout_constraintBottom_toTopOf="@id/tv_opponent_attack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_opponent_character"
        android:textAlignment="viewStart" />

    <!-- 공격력: 캐릭터 이름 바로 아래 세로 정렬 -->
    <TextView
        android:id="@+id/tv_opponent_attack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="65dp"
        android:text="Attack"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tv_opponent_character_name"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_opponent_hp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="65dp"
        android:text="HP"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tv_opponent_attack"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_opponent_dirt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="65dp"
        android:text="Dirt"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tv_opponent_hp"
        app:layout_constraintBottom_toBottomOf="@id/iv_opponent_character"
        app:layout_constraintStart_toStartOf="parent" />


    <!-- 현재 턴 정보 (중앙에 배치) -->
    <TextView
        android:id="@+id/tv_turn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="현재 턴"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FF000000"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/iv_opponent_character"
        app:layout_constraintBottom_toTopOf="@id/iv_my_character"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintHorizontal_bias="0.5" />

    <!-- 상대 스킬 횟수: 턴 정보 바로 위 -->

    <!-- 내 스킬 횟수: 턴 정보 바로 아래 -->
    <TextView
        android:id="@+id/tv_opponent_skill_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="70dp"
        android:padding="4dp"
        android:text="상대 스킬"
        android:textColor="#FF4081"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tv_turn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_my_skill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="70dp"
        android:padding="4dp"
        android:text="내 스킬"
        android:textColor="#3F51B5"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_turn" />


</androidx.constraintlayout.widget.ConstraintLayout>