<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:background="@drawable/view_card">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.16" />

        <TextView
            android:id="@+id/tv_Acquire"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="획득여부"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="7dp"
            app:layout_constraintBottom_toTopOf="@id/tv_Name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_Name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="35sp"
            app:layout_constraintTop_toTopOf="@id/guideline_top"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_chance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="출현 확률"
            android:textColor="#FFFFFF"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tv_Name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_Power"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="전투력"
            android:textColor="#FFFFFF"
            android:textAlignment="center"
            android:textSize="25sp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_chance"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_Power"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_Attack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Atk"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/imageView"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_HP"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HP"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/tv_Attack"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_Dirt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dirt"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/tv_HP"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_bottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.90" />

        <Button
            android:id="@+id/btn_get"
            style="@style/customButtonFontStyle"
            android:layout_width="127dp"
            android:layout_height="64dp"
            android:background="@drawable/button_get"
            android:layout_marginBottom="28dp"
            app:backgroundTint="@null"
            app:layout_constraintTop_toTopOf="@id/guideline_bottom"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />





    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
